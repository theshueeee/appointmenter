generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  name                 String 
  email                String    @unique
  password             String
  flag_count           Int       @default(0)
  banned_until         DateTime? @db.Timestamptz
  reschedule_count     Int       @default(0)
  last_reschedule_date DateTime? @db.Timestamptz // FIXED: changed 'data' to 'date'
  created_at           DateTime  @default(now()) @db.Timestamptz

  bookings Booking[]
}

model MeetingRoom {
  id       String            @id @default(uuid()) @db.Uuid
  name     String
  location String
  status   MeetingRoomStatus @default(AVAILABLE)

  bookings Booking[]
}

model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  user_id        String        @db.Uuid 
  meetingroom_id String        @db.Uuid
  start_time     DateTime      @db.Timestamptz
  end_time       DateTime      @db.Timestamptz
  status         BookingStatus @default(ACTIVE)
  version        Int           @default(1)
  created_at     DateTime      @default(now()) @db.Timestamptz
  updated_at     DateTime      @updatedAt @db.Timestamptz

  // Cascade delete handles user deletion perfectly
  user           User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  meetingroom    MeetingRoom   @relation(fields: [meetingroom_id], references: [id], onDelete: Restrict)
}

enum MeetingRoomStatus {
  AVAILABLE
  MAINTENANCE
  UNAVAILABLE
}

enum BookingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}