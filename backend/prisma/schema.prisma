// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id // Matches Clerk user_id
  name      String 
  email     String    @unique
  password  String
  flag_count   Int       @default(0)
  banned_until DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz

  bookings Booking[]
}

model MeetingRoom {
  id       String         @id @default(uuid()) @db.Uuid
  name     String
  location String
  status   MeetingRoomStatus @default(AVAILABLE)

  bookings Booking[]
}

model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  user_id     String?       // Optional because of SET NULL
  meetingroom_id String        @db.Uuid
  start_time  DateTime      @db.Timestamptz
  end_time    DateTime      @db.Timestamptz
  status      BookingStatus @default(ACTIVE)
  version     Int           @default(1)
  created_at  DateTime      @default(now()) @db.Timestamptz
  updated_at  DateTime      @updatedAt @db.Timestamptz

  user     User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  meetingroom MeetingRoom @relation(fields: [meetingroom_id], references: [id], onDelete: Restrict)
}

enum MeetingRoomStatus {
  AVAILABLE
  MAINTENANCE
  UNAVAILABLE
}

enum BookingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}